{
  "name": "@mempalace-ts/core",
  "version": "1.0.0",
  "description": "TypeScript-native memory palace for AI agents — core library",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc --build && cp -r src/instructions dist/",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "better-sqlite3": "11.9.1",
    "chromadb": "1.9.2",
    "p-limit": "6.2.0",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "typescript": "5.8.3",
    "vitest": "3.2.1"
  },
  "license": "MIT"
}
